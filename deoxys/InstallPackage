#!/usr/bin/env bash

set -euo pipefail

RED=$'\033[0;31m'
NC=$'\033[0m'

readonly DEFAULT_LIBFRANKA_VERSION="0.9.0"
readonly SUPPORTED_LIBFRANKA_VERSIONS=("0.8.0" "0.9.0" "0.10.0")
readonly SPDLOG_COMMIT="ac55e60488032b9acde8940a5de099541c4515da"
readonly PROTOBUF_VERSION="v3.13.0"

clone_if_missing() {
    local repo_url="$1"
    local target_dir="$2"
    local clone_flags=()

    if [[ "${3:-}" == "recursive" ]]; then
        clone_flags+=(--recursive)
    fi

    if [[ -d "${target_dir}/.git" ]]; then
        echo "Using existing ${target_dir} checkout"
        return
    fi

    git clone "${clone_flags[@]}" "${repo_url}" "${target_dir}"
}

is_supported_libfranka_version() {
    local version="$1"
    local supported
    for supported in "${SUPPORTED_LIBFRANKA_VERSIONS[@]}"; do
        if [[ "${supported}" == "${version}" ]]; then
            return 0
        fi
    done
    return 1
}

LIBFRANKA_VERSION="${LIBFRANKA_VERSION:-}"
if [[ -z "${LIBFRANKA_VERSION}" ]]; then
    if [[ -t 0 ]]; then
        echo "Which libfranka version are you going to use?"
        echo "Supported versions: ${SUPPORTED_LIBFRANKA_VERSIONS[*]}"
        read -r LIBFRANKA_VERSION
    else
        LIBFRANKA_VERSION="${DEFAULT_LIBFRANKA_VERSION}"
        echo "LIBFRANKA_VERSION not provided; defaulting to ${LIBFRANKA_VERSION}"
    fi
fi

echo "Selected libfranka ${LIBFRANKA_VERSION}"
if ! is_supported_libfranka_version "${LIBFRANKA_VERSION}"; then
    printf "${RED}Warning:${NC} libfranka %s is not one of the validated versions (%s)\n" \
        "${LIBFRANKA_VERSION}" "${SUPPORTED_LIBFRANKA_VERSIONS[*]}"
fi

sudo apt-get install -y \
    build-essential \
    cmake \
    git \
    libpoco-dev \
    libeigen3-dev \
    autoconf \
    automake \
    libtool \
    curl \
    make \
    g++ \
    unzip \
    libzmq3-dev \
    libreadline-dev \
    bzip2 \
    libmotif-dev \
    libglfw3 \
    python3-venv

clone_if_missing "https://github.com/frankaemika/libfranka" "libfranka" recursive
pushd libfranka >/dev/null
git fetch --tags
git checkout "${LIBFRANKA_VERSION}"
git submodule update --init --recursive
popd >/dev/null

clone_if_missing "https://github.com/zeromq/zmqpp.git" "zmqpp"
clone_if_missing "https://github.com/jbeder/yaml-cpp.git" "yaml-cpp"

clone_if_missing "https://github.com/gabime/spdlog.git" "spdlog"
pushd spdlog >/dev/null
git checkout "${SPDLOG_COMMIT}"
popd >/dev/null

clone_if_missing "https://github.com/protocolbuffers/protobuf.git" "protobuf" recursive
pushd protobuf >/dev/null
git checkout "${PROTOBUF_VERSION}"
git submodule update --init --recursive

if ! command -v protoc >/dev/null || [[ "$(protoc --version 2>/dev/null || true)" != "libprotoc 3.13.0" ]]; then
    ./autogen.sh
    ./configure
    make
    make check
    sudo make install
    sudo ldconfig
else
    echo "Found compatible protoc version; skipping protobuf source build"
fi
popd >/dev/null
